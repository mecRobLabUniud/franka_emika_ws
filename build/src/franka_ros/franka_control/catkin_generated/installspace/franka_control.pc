prefix=/home/panda/franka_emika_ws/install

Name: franka_control
Description: Description of franka_control
Version: 0.10.1
Cflags: -I${prefix}/include -I/opt/ros/melodic/include/libfranka
Libs: -L${prefix}/lib -lfranka_state_controller /opt/ros/melodic/lib/libfranka.so.0.9.0
Requires: controller_interface franka_hw franka_msgs geometry_msgs pluginlib realtime_tools roscpp sensor_msgs tf2_msgs std_srvs
